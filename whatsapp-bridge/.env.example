# === WhatsApp Bridge ===
PORT=3100
NODE_ENV=development

# Comunicação com API C#
API_BASE_URL=http://localhost:5000
BRIDGE_SECRET=DEV_WHATSAPP_SECRET_CHANGE_ME
WEBHOOK_SECRET=DEV_WEBHOOK_SECRET_CHANGE_ME

# Baileys
AUTH_DIR=./auth_data
LOG_LEVEL=info

# Opcional: Pairing Code (alternativa ao QR)
# Descomente e configure para usar pairing code em vez de QR
# PHONE_NUMBER=5511999999999

# ── Proteções Anti-Ban (valores padrão são seguros) ──
# Máx mensagens enviadas por minuto (todos os usuários)
# AB_GLOBAL_MAX_PER_MIN=30
# Jitter aleatório ±ms nos delays (quebra padrões robóticos)
# AB_JITTER_MS=500
# Cooldown mínimo (ms) entre enviar para números diferentes
# AB_CONV_COOLDOWN_MS=500
# Tamanho máximo de uma mensagem antes de ser dividida
# AB_MAX_MSG_LENGTH=1500
# Marcar mensagem como lida (✓✓ azul) antes de processar (true/false)
# AB_MARK_READ=true
